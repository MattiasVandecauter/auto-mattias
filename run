#!/usr/bin/env bash
# Start de autozoeker. Extra opties worden doorgegeven, bv: ./run --source all
set -euo pipefail

cd "$(dirname "$0")"

PY=".venv/bin/python"
if [ ! -x "$PY" ]; then
  echo "Geen .venv gevonden. Eerst opzetten:" >&2
  echo "  python3 -m venv .venv && .venv/bin/pip install -r requirements.txt" >&2
  exit 1
fi

exec "$PY" -m autoscraper.cli "$@"
